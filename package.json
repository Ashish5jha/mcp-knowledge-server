{
  "name": "mcp-knowledge-server",
  "version": "1.0.0",
  "description": "A Cloudflare Worker remote MCP server for personal knowledge bases stored in GitHub.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build:manifests": "node scripts/build-manifest.js --all",
    "build:manifest:company": "node scripts/build-manifest.js knowledge-base/company company",
    "build:manifest:personal": "node scripts/build-manifest.js knowledge-base/personal personal",
    "build:manifest:freelance": "node scripts/build-manifest.js knowledge-base/freelance freelance"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ashish5jha/mcp-knowledge-server.git"
  },
  "keywords": [
    "mcp",
    "cloudflare",
    "workers",
    "knowledge-base"
  ],
  "author": "Ashish Jha",
  "license": "ISC",
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "gray-matter": "^4.0.3",
    "typescript": "^7.0.2",
    "wrangler": "^4.110.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
